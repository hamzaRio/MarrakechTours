# Environment variables for MarrakechDeserts client application

# API URL - Use this for local development
VITE_API_URL=http://localhost:5000/api

# API URL - Use this when backend is deployed (uncomment when using)
# VITE_API_URL=https://your-backend-url.com/api 

# Optional: Analytics tracking ID if you add analytics
# VITE_ANALYTICS_ID=